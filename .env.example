# ClaritX — Frontend (Vite) environment variables
# Copy this file to `.env` and fill in the values from your backend SAM deploy outputs.
# All Vite client variables MUST be prefixed with VITE_ to be exposed to the browser.

# Base URL of the deployed FastAPI backend (API Gateway stage URL).
# Example shape: https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/prod
VITE_AWS_API_URL=your-api-gateway-url

# AWS Cognito User Pool ID (from the CognitoUserPoolId stack output).
# Note: the region prefix is encoded in this value (e.g. us-east-1_xxxxxxxxx).
VITE_COGNITO_USER_POOL_ID=your-cognito-user-pool-id

# AWS Cognito App Client ID (from the CognitoClientId stack output).
VITE_COGNITO_CLIENT_ID=your-cognito-app-client-id

# AWS region your backend is deployed in (e.g. us-east-1).
VITE_AWS_REGION=your-aws-region

# --- Optional ---
# Cognito Hosted UI domain for Google OAuth (from the CognitoDomain stack output).
# VITE_COGNITO_DOMAIN=your-cognito-domain.auth.us-east-1.amazoncognito.com
# Public site URL used for OAuth redirect callbacks.
# VITE_APP_URL=http://localhost:5173
# Google Analytics measurement ID.
# VITE_GA_MEASUREMENT_ID=your-ga-measurement-id

# ClaritX — Backend (FastAPI on AWS Lambda) environment variables
# Copy this file to `backend/.env` for local development. In production these are
# injected as Lambda environment variables via the SAM template parameters.
# NEVER commit real secrets — use placeholders only.

# --- Database ---
# PostgreSQL connection string. The app rewrites postgresql:// -> postgresql+asyncpg:// at runtime.
DATABASE_URL=postgresql://user:your-password@your-db-host:5432/claritx

# --- Finance data ---
# Financial Modeling Prep (FMP) API key.
FMP_API_KEY=your-fmp-api-key

# --- AI / LLM providers ---
# x.ai (Grok) API key.
XAI_API_KEY=your-xai-api-key
# Google Gemini / Vertex AI API key.
GEMINI_API_KEY=your-gemini-api-key

# --- Payments (Stripe) ---
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# --- Messaging (Twilio WhatsApp) ---
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
# Twilio WhatsApp sender (e.g. whatsapp:+14155238886).
TWILIO_WHATSAPP_FROM=your-twilio-whatsapp-from

# --- Async workers (Amazon SQS) ---
# Queue URL for UI-initiated stock analysis jobs.
SQS_QUEUE_URL=your-sqs-queue-url
# Queue URL for heavy batch ranking jobs.
BATCH_QUEUE_URL=your-batch-queue-url
# Queue URL for background tasks (market scan, blog generation, deep search).
SQS_BACKGROUND_QUEUE_URL=your-background-queue-url

# --- AWS Cognito (token verification) ---
COGNITO_USER_POOL_ID=your-cognito-user-pool-id
COGNITO_CLIENT_ID=your-cognito-app-client-id

# --- Google Cloud (Vertex AI batch + GCS) ---
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GCS_BUCKET_NAME=your-gcs-bucket-name
# Path to a GCP service-account JSON file, or the JSON itself (local dev only).
# GOOGLE_APPLICATION_CREDENTIALS=./gcp-credentials.json

# --- Misc ---
AWS_DEFAULT_REGION=your-aws-region
# Batch backend provider: google_batch or kie_direct.
BATCH_PROVIDER=google_batch
